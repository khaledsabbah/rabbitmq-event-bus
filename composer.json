{
    "name": "kg_coder/eventbus",
    "description": "Tenancy-agnostic event bus for IdaraTech microservices",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "php-amqplib/php-amqplib": "^3.7",
        "ramsey/uuid": "^4.7",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/log": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Idaratech\\EventBus\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Idaratech\\EventBus\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Idaratech\\EventBus\\EventBusServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
